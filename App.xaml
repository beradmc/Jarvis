             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JarvisCSharp">
    <Application.Resources>
        <!-- Renk Paleti -->
        <SolidColorBrush x:Key="BgBrush" Color="#050814"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#6366f1"/>
