        <SolidColorBrush x:Key="PanelBrush" Color="#0b0f19"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#10b981"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#06b6d4"/>
        <SolidColorBrush x:Key="RedBrush" Color="#ef4444"/>
