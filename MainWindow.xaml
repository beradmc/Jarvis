<Window x:Class="JarvisCSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JarvisCSharp"
        mc:Ignorable="d"
        Title="JARVIS Windows - C#" 
        Height="860" Width="1400" 
        MinHeight="620" MinWidth="900"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource DimmerBrush}" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="J.A.R.V.I.S" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="  ·  " 
                               FontSize="20" 
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="VOICE CORE · Windows" 
                               FontSize="14" 
                               Foreground="{StaticResource OrangeBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="⚙ SETTINGS" 
                            Background="Transparent" Foreground="{StaticResource DimBrush}" 
                            BorderThickness="0" Margin="0,0,20,0" VerticalAlignment="Center"
                            Click="SettingsButton_Click" Cursor="Hand" />
                    <TextBlock x:Name="StatusText" 
                               Text="INITIALIZING" 
                               FontSize="12" 
                               Foreground="{StaticResource GreenBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="410"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - System Info & Health Data -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" 
                    BorderBrush="{StaticResource DimBrush}" BorderThickness="1"
                    Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="SYSTEM" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource PrimaryBrush}"
                                   Margin="0,0,0,15"/>
                        
                        <TextBlock x:Name="TimeText" 
                                   Text="--:--:--" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock x:Name="DateText" 
                                   Text="Loading..." 
                                   FontSize="14" 
                                   Foreground="{StaticResource OrangeBrush}"
                                   Margin="0,0,0,20"/>
                        
                        <Separator Background="{StaticResource DimBrush}" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="CPU" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,5"/>
                        <ProgressBar x:Name="CpuProgressBar" Height="8" Margin="0,0,0,15" 
                                     Foreground="{StaticResource PrimaryBrush}" Background="{StaticResource DimBrush}"/>
                        
                        <TextBlock Text="RAM" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,5"/>
                        <ProgressBar x:Name="RamProgressBar" Height="8" Margin="0,0,0,15" 
                                     Foreground="{StaticResource OrangeBrush}" Background="{StaticResource DimBrush}"/>
                        
                        <TextBlock Text="BATTERY" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,5"/>
                        <ProgressBar x:Name="BatteryProgressBar" Height="8" Margin="0,0,0,15" 
                                     Foreground="{StaticResource GreenBrush}" Background="{StaticResource DimBrush}"/>
                        
                        <!-- Health Hologram Panel -->
                        <Border x:Name="HealthPanel" 
                                Background="{StaticResource DimmerBrush}" 
                                BorderBrush="{StaticResource DimBrush}" 
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,20,0,0"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="⚡ HEALTH DATA" 
                                           FontSize="14" 
                                           FontWeight="Bold" 
                                           Foreground="{StaticResource GreenBrush}"
                                           Margin="0,0,0,12"/>
                                
                                <!-- Health Metric Lines (Up to 5 key metrics) -->
                                <TextBlock x:Name="HealthMetric1" 
                                           Text="" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,6"
                                           Visibility="Collapsed"/>
                                
                                <TextBlock x:Name="HealthMetric2" 
                                           Text="" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,6"
                                           Visibility="Collapsed"/>
                                
                                <TextBlock x:Name="HealthMetric3" 
                                           Text="" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,6"
                                           Visibility="Collapsed"/>
                                
                                <TextBlock x:Name="HealthMetric4" 
                                           Text="" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,6"
                                           Visibility="Collapsed"/>
                                
                                <TextBlock x:Name="HealthMetric5" 
                                           Text="" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="0,0,0,0"
                                           Visibility="Collapsed"/>
                                
                                <!-- Data Age/Source Info -->
                                <TextBlock x:Name="HealthDataAge" 
                                           Text="" 
                                           FontSize="9" 
                                           Foreground="{StaticResource DimBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Center Panel - 3D Head & Visualization -->
            <Border Grid.Column="1" Background="{StaticResource DimBrush}" 
                    BorderBrush="{StaticResource DimBrush}" BorderThickness="1">
                <Grid>
                    <!-- 3D Head Mesh -->
                    <Border Background="{StaticResource DimmerBrush}" 
                            CornerRadius="10"
                            Margin="50" ClipToBounds="True">
                        <Image x:Name="HologramImage" Stretch="Uniform" />
                    </Border>

                    <!-- Status Indicator -->
                    <Ellipse x:Name="StatusOrb" 
                             Width="120" Height="120" 
                             Fill="{StaticResource GreenBrush}"
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Center"
                             Opacity="0.3"/>
                </Grid>
            </Border>

            <!-- Right Panel - Logs & Controls -->
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" 
                    BorderBrush="{StaticResource DimBrush}" BorderThickness="1"
                    Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ACTIVITY LOG" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="LogText" 
                                   Text="JARVIS initializing..." 
                                   FontSize="11" 
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <TextBox x:Name="CommandInput" 
                                 Height="34" 
                                 FontSize="12" 
                                 Background="{StaticResource DimBrush}" 
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource PrimaryBrush}"
                                 Padding="10,5"
                                 VerticalContentAlignment="Center"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="MuteButton" 
                                    Content="MUTE" 
                                    Width="80" Height="30" 
                                    Margin="0,0,5,0"
                                    Background="{StaticResource DimBrush}" 
                                    Foreground="{StaticResource TextBrush}"
                                    BorderBrush="{StaticResource PrimaryBrush}"/>
                            
                            <Button x:Name="PauseButton" 
                                    Content="PAUSE" 
                                    Width="80" Height="30" 
                                    Margin="0,0,5,0"
                                    Background="{StaticResource DimBrush}" 
                                    Foreground="{StaticResource TextBrush}"
                                    BorderBrush="{StaticResource PrimaryBrush}"/>
                            
                            <Button x:Name="StopButton" 
                                    Content="STOP" 
                                    Width="80" Height="30" 
                                    Background="{StaticResource RedBrush}" 
                                    Foreground="White"
                                    BorderBrush="Transparent"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource DimmerBrush}" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="JARVIS Windows C# Edition · Berat Demirci" 
                           FontSize="10" 
                           Foreground="{StaticResource DimBrush}"
                           VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="1" 
                           x:Name="ModelBadge" 
                           Text="Gemini 2.5 Flash" 
                           FontSize="10" 
                           Foreground="{StaticResource OrangeBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
