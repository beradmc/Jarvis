<Window x:Class="JarvisCSharp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JARVIS Settings" Height="450" Width="400"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="AUTOMATION SETTINGS" 
                   FontSize="18" FontWeight="Bold" Foreground="#FF9600" 
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <!-- Sandbox Mode -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Sandbox Mode:" Width="150" VerticalAlignment="Center"/>
                <CheckBox x:Name="SandboxToggle" Content="Enable" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Confirmation Level -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Confirmation Level:" Width="150" VerticalAlignment="Center"/>
                <ComboBox x:Name="ConfirmationLevelCombo" Width="120" Background="#2D2D30" Foreground="White">
                    <ComboBoxItem Content="Low" Tag="low"/>
                    <ComboBoxItem Content="Medium" Tag="medium"/>
                    <ComboBoxItem Content="High" Tag="high"/>
                </ComboBox>
            </StackPanel>

            <!-- Automation Speed -->
            <StackPanel Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Automation Speed:" Width="150"/>
                    <TextBlock x:Name="SpeedValueText" Text="1.0x" Foreground="#00C8B4"/>
                </StackPanel>
                <Slider x:Name="SpeedSlider" Minimum="0.5" Maximum="2.0" TickFrequency="0.1" IsSnapToTickEnabled="True" 
                        Value="1.0" Margin="0,5,0,0" ValueChanged="SpeedSlider_ValueChanged"/>
            </StackPanel>

            <!-- Timeouts -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Timeouts (ms):" Width="150" VerticalAlignment="Center"/>
                <TextBox x:Name="TimeoutText" Width="100" Background="#2D2D30" Foreground="White" Padding="2"
                         PreviewTextInput="TimeoutText_PreviewTextInput"/>
            </StackPanel>
            
            <TextBlock Text="Whitelist management and per-app overrides are configured in api_keys.json." 
                       FontSize="10" Foreground="#888888" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="CancelButton_Click" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="5"/>
            <Button Content="Save" Width="80" Click="SaveButton_Click" Background="#00C8B4" Foreground="Black" FontWeight="Bold" BorderThickness="0" Padding="5"/>
        </StackPanel>
    </Grid>
</Window>
